# Zend Lead Integration Config

# 1. GHL Authentication Key (API v2 Location Access Token)
# If blank, the server runs in "Sandbox/Simulated" mode and logs GHL payloads.
GHL_API_KEY=""

# 2. GHL Target Location ID (associated with sub-account)
GHL_LOCATION_ID=""

# 3. GHL Sales Pipeline Config (Where leads are dropped as opportunities)
GHL_PIPELINE_ID="zend_merchant_pipeline"
GHL_STAGE_ID="lead_inflow_stage"

# 4. Port configuration
PORT=8080
